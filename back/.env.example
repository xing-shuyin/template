IS_PRODUCTION=false
PROJECT_NAME=BLOG
API="/api"
ORIGINS=http://localhost:3000, http://localhost:5173, http://localhost:8000
ALLOW_HOSTS=["localhost","127.0.0.1"]

# JWT（生产环境务必更换）
SECRET_KEY=change-this-to-a-random-secret-key
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-this-password

# HOST
SERVER_HOST=http://localhost:8090
BACK_HOST=0.0.0.0
BACK_PORT=8090

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_db
PG_USER=postgres
PG_PASSWORD=change-this-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=change-this-password

# Emails
SMTP_HOST=smtp.example.com
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
EMAILS_FROM_EMAIL=your-email@example.com
SMTP_SSL=True
SMTP_PORT=465
